# SNF Agentic Platform — Environment Variables
# Copy to .env and fill in real values when Ensign provides credentials.

# --- Anthropic (Claude Agent SDK) ---
ANTHROPIC_API_KEY=placeholder_anthropic_api_key

# --- PostgreSQL ---
DATABASE_URL=postgresql://snf:snf_dev@localhost:5432/snf_platform
DATABASE_SSL=false

# --- PCC (PointClickCare) ---
PCC_CLIENT_ID=placeholder_pcc_client_id
PCC_CLIENT_SECRET=placeholder_pcc_client_secret
PCC_BASE_URL=https://api.pointclickcare.com/v1
PCC_TOKEN_URL=https://api.pointclickcare.com/oauth/token

# --- Workday ---
WORKDAY_CLIENT_ID=placeholder_workday_client_id
WORKDAY_CLIENT_SECRET=placeholder_workday_client_secret
WORKDAY_TENANT_ID=placeholder_workday_tenant_id
WORKDAY_BASE_URL=https://TENANT.workday.com/api/v1

# --- Microsoft 365 ---
M365_CLIENT_ID=placeholder_m365_client_id
M365_CLIENT_SECRET=placeholder_m365_client_secret
M365_TENANT_ID=placeholder_m365_tenant_id

# --- CMS / Regulatory ---
CMS_API_KEY=placeholder_cms_api_key
OIG_API_KEY=placeholder_oig_api_key

# --- API Server ---
API_PORT=3001
API_HOST=0.0.0.0
WS_PORT=3002

# --- Logging ---
LOG_LEVEL=info
NODE_ENV=development
